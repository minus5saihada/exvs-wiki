# Payload CMS
# Use localhost when running `pnpm dev` natively on the host; docker-compose overrides
# this to point at the payload-db service when running the web service in Docker.
DATABASE_URL=postgresql://payload:payload@localhost:5432/exvs_wiki
PAYLOAD_SECRET=changeme-generate-a-long-random-string

# PocketBase
PB_ENCRYPTION_KEY=changeme-generate-a-32-char-string
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# Umami
UMAMI_APP_SECRET=changeme-generate-a-long-random-string
NEXT_PUBLIC_UMAMI_URL=http://localhost:3001
